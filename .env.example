# Server-only — never prefix with NEXT_PUBLIC_
GOOGLE_MAPS_PLATFORM_KEY=your_google_maps_api_key_here

# Public URL for client share links (heatmap + site audit).
# Use your live domain when developing locally so copied links are not localhost.
# PUBLIC_APP_URL=https://your-live-site.com

# Enable these APIs in Google Cloud Console for the same key:
# - Places API (New)
# - Maps Static API
# - PageSpeed Insights API (website audit)

# Optional: custom SQLite database path (default: data/leads.db)
# DATABASE_PATH=data/leads.db

# Max leads per category per search (1–60, default 60). Fetches up to 3 Google pages.
# PLACES_MAX_RESULTS_PER_CATEGORY=60
